{
  "name": "octelium-authserver",
  "private": true,
  "version": "0.0.0-main",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "build-dev": "tsc && vite build --mode development",
    "build-staging": "tsc && vite build --mode staging",
    "protoc-gen-auth": "npx protoc --ts_out ./tmp --ts_opt long_type_number --proto_path ../../../../../../pb apis/protobuf/main/authv1/authv1.proto",
    "protoc-gen-meta": "npx protoc --ts_out ./tmp --ts_opt long_type_number --proto_path ../../../../../../pb apis/protobuf/main/metav1/metav1.proto",
    "protoc-gen": "mkdir -p ./tmp/apis/protobuf && npm run protoc-gen-meta && npm run protoc-gen-auth",
    "protoc-cp": "cp -r ./tmp/apis/protobuf/main/metav1 ./src/apis && cp -r ./tmp/apis/protobuf/main/authv1 ./src/apis && find ./src -name \"*.proto\" -type f -delete",
    "protoc-fix": "find ./src/apis -name '*.ts' -exec sed -i s#../../../../google/protobuf#../google/protobuf#g {} +",
    "protoc": "npm run protoc-gen && npm run protoc-cp && npm run protoc-fix"
  },
  "dependencies": {
    "@mantine/core": "^8.3.15",
    "@mantine/hooks": "^8.3.15",
    "@octelium/apis": "^1.0.0-pre.20260321.1",
    "@protobuf-ts/grpcweb-transport": "2.11",
    "@protobuf-ts/plugin": "2.11",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "dayjs": "^1.11.19",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-otp-input": "^3.1.1",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "vite-plugin-svgr": "^4.5.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "postcss": "^8.5.8",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.97.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
}
